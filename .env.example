# =================================================
# OmniChat AI — Environment Configuration
# =================================================
# คัดลอกเป็น .env.local แล้วใส่ค่าจริง

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase ----
# https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...    # ห้าม expose ฝั่ง client

# ---- Chat source API (ecom-data-platform / TikTok Shop proxy) ----
CHAT_API_BASE_URL=https://ecom-data-platform.onrender.com
CHAT_API_KEY=                          # X-API-Key for the chat proxy

# ---- AI / LLM ----
LLM_PROVIDER=mock                      # mock | openai | anthropic
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Generic ingest endpoint (/api/webhooks/ingest) ----
# Required to enable the test ingest endpoint. If unset, the endpoint returns 404.
# Send the value in the `x-ingest-token` header.
INGEST_SECRET=

# ---- LINE Messaging API ----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ---- Facebook & Instagram ----
META_VERIFY_TOKEN=set-any-string-here
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=

# ---- Shopee Open Platform ----
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# ---- TikTok Shop ----
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

# ---- Lazada Open Platform ----
LAZADA_APP_KEY=
LAZADA_APP_SECRET=

# ---- WhatsApp Cloud API ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
